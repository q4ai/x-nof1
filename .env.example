# ===========================================
# AI 加密货币自动交易系统 - 环境变量配置
# ===========================================
# 
# 注意：从 v2.0 开始，大部分配置已迁移到数据库管理
# 可通过 Web 界面（右上角设置按钮）动态修改配置
# 此文件仅保留必需的启动参数
# ===========================================

# ============================================
# 必需配置（无法通过 Web 界面修改）
# ============================================

# Web 服务器监听端口
PORT=3100

# 数据库连接 URL
# 使用本地 SQLite: file:./data/database/sqlite.db
# 使用远程 Turso: libsql://your-database.turso.io
DATABASE_URL=file:./data/database/sqlite.db

# ============================================
# 可选：首次启动时从环境变量初始化配置
# 后续可通过 Web 设置界面管理，无需修改此文件
# ============================================

# OKX API 配置（首次启动时初始化到数据库）
OKX_API_KEY=your_api_key_here
OKX_API_SECRET=your_api_secret_here
OKX_API_PASSPHRASE=your_passphrase_here
OKX_USE_PAPER=true

# OpenAI API 配置
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://openrouter.ai/api/v1
AI_MODEL_NAME=deepseek/deepseek-v3.2-exp

# 网络代理（可选）
HTTP_PROXY_URL=

# 交易配置
TRADING_SYMBOLS=BTC,ETH,SOL,XRP,BNB,BCH
TRADING_INTERVAL_MINUTES=20

# 风险参数
MAX_LEVERAGE=10
MAX_POSITIONS=5
MAX_HOLDING_HOURS=36
EXTREME_STOP_LOSS_PERCENT=-30

# 账户参数
INITIAL_BALANCE=100
ACCOUNT_STOP_LOSS_USDT=50
ACCOUNT_TAKE_PROFIT_USDT=20000

# 回撤风控
ACCOUNT_DRAWDOWN_WARNING_PERCENT=20
ACCOUNT_DRAWDOWN_NO_NEW_POSITION_PERCENT=30
ACCOUNT_DRAWDOWN_FORCE_CLOSE_PERCENT=50

# ============================================
# 使用说明
# ============================================
# 1. 首次启动时，复制此文件为 .env 并填写配置
# 2. 启动服务后，所有配置将自动同步到数据库
# 3. 后续通过 Web 界面（http://localhost:3100）右上角设置按钮管理配置
# 4. 详细说明请参考：docs/CONFIG_MANAGEMENT.md
